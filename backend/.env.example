# MongoDB Atlas connection string
# Get this from https://cloud.mongodb.com -> Database -> Connect -> Drivers
MONGODB_URI=mongodb://ecovillage_admin:7gbFUPYxGR6aZvku@ac-vgcygsp-shard-00-00.2p0jcov.mongodb.net:27017,ac-vgcygsp-shard-00-01.2p0jcov.mongodb.net:27017,ac-vgcygsp-shard-00-02.2p0jcov.mongodb.net:27017/ecovillage?ssl=true&replicaSet=atlas-3z74ep-shard-0&authSource=admin&retryWrites=true&w=majority

# Secret used to sign JWT tokens. Use a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# Cloudinary (image hosting) - get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# Port the server runs on locally (Render sets this automatically in production)
PORT=5000

# Comma-separated list of allowed frontend origins (for CORS)
# e.g. http://localhost:3000,https://yourdomain.com
CLIENT_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,https://your-frontend-domain.vercel.app

# The very first admin account is created via a one-time seed script (see scripts/createAdmin.js)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_a_strong_password

# Telegram bot notifications (instant alert to your phone when a partner submits a listing)
# See src/config/telegram.js for the 2-minute setup steps.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
